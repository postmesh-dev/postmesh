{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "namespace": {
      "default": "local",
      "description": "Workflow namespace (default: local)",
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$"
    },
    "name": {
      "description": "Workflow name",
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$"
    },
    "version": {
      "default": 1,
      "description": "Workflow config version",
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "description": {
      "description": "Human-readable description of this workflow",
      "type": "string"
    },
    "collections": {
      "default": {},
      "description": "Collection definitions in this workflow",
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
            "description": "Collection name"
          },
          "description": {
            "description": "Human-readable description of this collection",
            "type": "string"
          },
          "version": {
            "default": 1,
            "description": "Collection config version",
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "backend": {
            "default": {
              "type": "json_records"
            },
            "description": "Storage backend type",
            "type": "object",
            "properties": {
              "type": {
                "default": "json_records",
                "type": "string",
                "enum": [
                  "json_records",
                  "table"
                ]
              }
            }
          },
          "schema": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "string",
                    "number",
                    "integer",
                    "boolean",
                    "date",
                    "datetime",
                    "json"
                  ],
                  "description": "Expected value type for this field"
                },
                "required": {
                  "default": false,
                  "type": "boolean"
                },
                "nullable": {
                  "default": true,
                  "type": "boolean"
                },
                "description": {
                  "type": "string"
                },
                "enum": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "default": {},
                "indexed": {
                  "default": false,
                  "type": "boolean"
                }
              },
              "required": [
                "type"
              ],
              "description": "Schema definition for a single collection field"
            },
            "description": "Field definitions for records stored in this collection"
          },
          "key": {
            "type": "object",
            "properties": {
              "fields": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 64,
                  "pattern": "^[A-Za-z][A-Za-z0-9_]*$",
                  "description": "Collection field name. Must start with a letter and contain only letters, numbers, and underscores. Leading underscore is reserved for system fields."
                }
              },
              "separator": {
                "default": ":",
                "type": "string"
              }
            },
            "required": [
              "fields"
            ],
            "description": "Record key definition — determines uniqueness"
          },
          "indexes": {
            "default": [],
            "description": "Secondary indexes for efficient querying",
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "fields": {
                  "minItems": 1,
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "unique": {
                  "default": false,
                  "type": "boolean"
                },
                "name": {
                  "type": "string"
                }
              },
              "required": [
                "fields"
              ],
              "description": "Index definition for a collection"
            }
          },
          "retain": {
            "description": "Retention policy for old records",
            "type": "object",
            "properties": {
              "max_age": {
                "description": "Maximum age before automatic cleanup",
                "type": "string"
              }
            }
          }
        },
        "required": [
          "name",
          "schema",
          "key"
        ],
        "description": "Declarative collection definition"
      }
    },
    "pipelines": {
      "default": {},
      "description": "Pipeline definitions in this workflow",
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
            "description": "Pipeline name"
          },
          "description": {
            "description": "Human-readable description of this pipeline",
            "type": "string"
          },
          "version": {
            "default": 1,
            "description": "Pipeline config version",
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "enabled": {
            "default": true,
            "description": "Whether this pipeline is enabled and can be run",
            "type": "boolean"
          },
          "source": {
            "type": "object",
            "properties": {
              "type": {
                "default": "messages",
                "description": "Source type (only 'messages' supported)",
                "type": "string",
                "const": "messages"
              },
              "query": {
                "type": "object",
                "properties": {
                  "filter": {
                    "description": "Filter criteria",
                    "type": "object",
                    "properties": {
                      "from": {
                        "description": "Filter by sender email address(es)",
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          }
                        ]
                      },
                      "to": {
                        "description": "Filter by recipient email address(es)",
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          }
                        ]
                      },
                      "subject": {
                        "description": "Keywords to match in subject",
                        "type": "string"
                      },
                      "body": {
                        "description": "Keywords to match in body preview",
                        "type": "string"
                      },
                      "received_at": {
                        "description": "Received-at time range filter",
                        "type": "object",
                        "properties": {
                          "gte": {
                            "description": "Only messages received at or after this timestamp",
                            "type": "string"
                          },
                          "lte": {
                            "description": "Only messages received at or before this timestamp",
                            "type": "string"
                          }
                        }
                      },
                      "is_read": {
                        "description": "Filter by read state",
                        "type": "boolean"
                      },
                      "folder": {
                        "description": "Filter by folder identifier (e.g. inbox, archive)",
                        "type": "string"
                      },
                      "query": {
                        "description": "Full-text search query (uses FTS5, matches subject + body)",
                        "type": "string"
                      },
                      "labels": {
                        "description": "Filter by Gmail labels",
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    },
                    "additionalProperties": false
                  },
                  "sort": {
                    "description": "Sort specification",
                    "type": "object",
                    "properties": {
                      "field": {
                        "default": "received_at",
                        "description": "Field to sort by",
                        "type": "string",
                        "enum": [
                          "received_at",
                          "last_modified"
                        ]
                      },
                      "order": {
                        "default": "desc",
                        "description": "Sort direction",
                        "type": "string",
                        "enum": [
                          "asc",
                          "desc"
                        ]
                      }
                    },
                    "additionalProperties": false
                  },
                  "page": {
                    "default": {
                      "limit": 20
                    },
                    "description": "Pagination settings",
                    "type": "object",
                    "properties": {
                      "limit": {
                        "default": 20,
                        "description": "Maximum number of messages to return",
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "maximum": 100
                      },
                      "cursor": {
                        "description": "Opaque cursor returned from a previous page",
                        "type": "string"
                      }
                    },
                    "additionalProperties": false
                  },
                  "select": {
                    "description": "Subset of message fields to return",
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "id",
                        "subject",
                        "from_email",
                        "body_preview",
                        "received_at"
                      ]
                    }
                  }
                },
                "additionalProperties": false,
                "description": "Message query/filter to select source messages"
              },
              "include": {
                "description": "Controls which message parts are included for processing",
                "type": "object",
                "properties": {
                  "body": {
                    "default": true,
                    "description": "Include full message body",
                    "type": "boolean"
                  },
                  "headers": {
                    "default": true,
                    "description": "Include message headers",
                    "type": "boolean"
                  },
                  "thread": {
                    "default": false,
                    "description": "Include thread/context messages",
                    "type": "boolean"
                  },
                  "attachments": {
                    "default": false,
                    "description": "Include attachment metadata",
                    "type": "boolean"
                  }
                }
              },
              "limit": {
                "description": "Maximum number of messages to process per run",
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 10000
              }
            },
            "required": [
              "query"
            ],
            "description": "Source query configuration for finding messages"
          },
          "process": {
            "minItems": 1,
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "type": "object",
                  "properties": {
                    "classify": {
                      "type": "object",
                      "properties": {
                        "field": {
                          "type": "string",
                          "description": "Target field to store the classification result (e.g. data.kind)"
                        },
                        "enum": {
                          "description": "Allowed classification values. The engine or regex rules must return one of these",
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "boolean": {
                          "description": "When true, classify as true/false instead of using enum values",
                          "type": "boolean"
                        },
                        "instructions": {
                          "description": "Natural language instructions for the engine, describing how to classify messages",
                          "type": "string"
                        },
                        "confidence_field": {
                          "description": "Field to store the classification confidence score (0.0-1.0)",
                          "type": "string"
                        },
                        "using": {
                          "default": "engine",
                          "description": "Execution strategy. regex uses deterministic regex rules. engine uses the LLM for semantic judgement.",
                          "type": "string",
                          "enum": [
                            "regex",
                            "engine"
                          ]
                        },
                        "rules": {
                          "description": "Regex classification rules used when using=regex",
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "label": {
                                "type": "string",
                                "description": "Classification label to emit when this rule matches"
                              },
                              "match": {
                                "anyOf": [
                                  {
                                    "type": "object",
                                    "properties": {
                                      "pattern": {
                                        "type": "string",
                                        "description": "Regular expression pattern used to match the input text"
                                      },
                                      "flags": {
                                        "default": "i",
                                        "description": "JavaScript RegExp flags used when compiling the pattern",
                                        "type": "string",
                                        "pattern": "^[dgimsuvy]*$"
                                      },
                                      "input": {
                                        "default": "text",
                                        "description": "Message field to run the regex against. text means a combined searchable representation such as subject plus body.",
                                        "type": "string",
                                        "enum": [
                                          "subject",
                                          "body",
                                          "headers",
                                          "from",
                                          "to",
                                          "text"
                                        ]
                                      },
                                      "group": {
                                        "default": 0,
                                        "description": "Capture group to read from the match. Use 0 for the full match, a number for a numbered group, or a string for a named group.",
                                        "anyOf": [
                                          {
                                            "type": "integer",
                                            "minimum": 0,
                                            "maximum": 9007199254740991
                                          },
                                          {
                                            "type": "string"
                                          }
                                        ]
                                      },
                                      "all": {
                                        "default": false,
                                        "description": "Whether to return all matches instead of only the first match",
                                        "type": "boolean"
                                      },
                                      "trim": {
                                        "default": true,
                                        "description": "Whether to trim extracted string values",
                                        "type": "boolean"
                                      },
                                      "normalize": {
                                        "default": "none",
                                        "description": "Optional normalization applied to extracted string values",
                                        "type": "string",
                                        "enum": [
                                          "none",
                                          "lowercase",
                                          "uppercase"
                                        ]
                                      }
                                    },
                                    "required": [
                                      "pattern"
                                    ],
                                    "description": "Regex match definition"
                                  },
                                  {
                                    "type": "array",
                                    "items": {
                                      "type": "object",
                                      "properties": {
                                        "pattern": {
                                          "type": "string",
                                          "description": "Regular expression pattern used to match the input text"
                                        },
                                        "flags": {
                                          "default": "i",
                                          "description": "JavaScript RegExp flags used when compiling the pattern",
                                          "type": "string",
                                          "pattern": "^[dgimsuvy]*$"
                                        },
                                        "input": {
                                          "default": "text",
                                          "description": "Message field to run the regex against. text means a combined searchable representation such as subject plus body.",
                                          "type": "string",
                                          "enum": [
                                            "subject",
                                            "body",
                                            "headers",
                                            "from",
                                            "to",
                                            "text"
                                          ]
                                        },
                                        "group": {
                                          "default": 0,
                                          "description": "Capture group to read from the match. Use 0 for the full match, a number for a numbered group, or a string for a named group.",
                                          "anyOf": [
                                            {
                                              "type": "integer",
                                              "minimum": 0,
                                              "maximum": 9007199254740991
                                            },
                                            {
                                              "type": "string"
                                            }
                                          ]
                                        },
                                        "all": {
                                          "default": false,
                                          "description": "Whether to return all matches instead of only the first match",
                                          "type": "boolean"
                                        },
                                        "trim": {
                                          "default": true,
                                          "description": "Whether to trim extracted string values",
                                          "type": "boolean"
                                        },
                                        "normalize": {
                                          "default": "none",
                                          "description": "Optional normalization applied to extracted string values",
                                          "type": "string",
                                          "enum": [
                                            "none",
                                            "lowercase",
                                            "uppercase"
                                          ]
                                        }
                                      },
                                      "required": [
                                        "pattern"
                                      ],
                                      "description": "Regex match definition"
                                    }
                                  }
                                ],
                                "description": "One or more regex matches that trigger this label"
                              },
                              "require": {
                                "default": "any",
                                "description": "Whether any match or all matches are required for this rule to trigger",
                                "type": "string",
                                "enum": [
                                  "any",
                                  "all"
                                ]
                              }
                            },
                            "required": [
                              "label",
                              "match"
                            ],
                            "description": "One regex-backed classification rule"
                          }
                        },
                        "default": {
                          "description": "Default classification label if no regex rules match",
                          "type": "string"
                        }
                      },
                      "required": [
                        "field"
                      ]
                    }
                  },
                  "required": [
                    "classify"
                  ],
                  "description": "Classify messages into categories using regex rules or an LLM engine"
                },
                {
                  "type": "object",
                  "properties": {
                    "extract": {
                      "type": "object",
                      "properties": {
                        "schema": {
                          "description": "Target collection schema (by name or inline) that defines which fields to extract",
                          "anyOf": [
                            {
                              "type": "string"
                            },
                            {
                              "type": "object",
                              "propertyNames": {
                                "type": "string"
                              },
                              "additionalProperties": {
                                "type": "object",
                                "properties": {
                                  "type": {
                                    "type": "string",
                                    "enum": [
                                      "string",
                                      "number",
                                      "integer",
                                      "boolean",
                                      "date",
                                      "datetime",
                                      "json"
                                    ],
                                    "description": "Expected value type for this field"
                                  },
                                  "required": {
                                    "default": false,
                                    "type": "boolean"
                                  },
                                  "nullable": {
                                    "default": true,
                                    "type": "boolean"
                                  },
                                  "description": {
                                    "type": "string"
                                  },
                                  "enum": {
                                    "type": "array",
                                    "items": {
                                      "type": "string"
                                    }
                                  },
                                  "default": {},
                                  "indexed": {
                                    "default": false,
                                    "type": "boolean"
                                  }
                                },
                                "required": [
                                  "type"
                                ],
                                "description": "Schema definition for a single collection field"
                              }
                            }
                          ]
                        },
                        "instructions": {
                          "description": "Natural language instructions for the engine, describing what to extract and when to accept or reject",
                          "type": "string"
                        },
                        "evidence": {
                          "default": false,
                          "description": "When true, store evidence quotes alongside extracted values for auditability",
                          "type": "boolean"
                        },
                        "confidence_field": {
                          "description": "Field to store extraction confidence score (0.0-1.0)",
                          "type": "string"
                        },
                        "many": {
                          "default": false,
                          "description": "Allow extraction of multiple records from a single message",
                          "type": "boolean"
                        },
                        "using": {
                          "default": "engine",
                          "description": "Execution strategy. regex uses deterministic regex patterns. engine uses the LLM for semantic extraction.",
                          "type": "string",
                          "enum": [
                            "regex",
                            "engine"
                          ]
                        },
                        "fields": {
                          "description": "Regex-backed field extraction definitions used when using=regex",
                          "type": "object",
                          "propertyNames": {
                            "type": "string"
                          },
                          "additionalProperties": {
                            "type": "object",
                            "properties": {
                              "pattern": {
                                "type": "string",
                                "description": "Regular expression pattern used to extract this field"
                              },
                              "flags": {
                                "default": "i",
                                "description": "JavaScript RegExp flags used when compiling the pattern",
                                "type": "string",
                                "pattern": "^[dgimsuvy]*$"
                              },
                              "input": {
                                "default": "text",
                                "description": "Message field to run the regex against. text means a combined searchable representation such as subject plus body.",
                                "type": "string",
                                "enum": [
                                  "subject",
                                  "body",
                                  "headers",
                                  "from",
                                  "to",
                                  "text"
                                ]
                              },
                              "group": {
                                "default": 1,
                                "description": "Capture group to extract. Defaults to group 1 because extraction usually uses the first capture group.",
                                "anyOf": [
                                  {
                                    "type": "integer",
                                    "minimum": 0,
                                    "maximum": 9007199254740991
                                  },
                                  {
                                    "type": "string"
                                  }
                                ]
                              },
                              "all": {
                                "default": false,
                                "description": "Whether to extract all matches as an array",
                                "type": "boolean"
                              },
                              "type": {
                                "description": "Optional output type coercion. If omitted, use the target collection field type when available.",
                                "type": "string",
                                "enum": [
                                  "string",
                                  "number",
                                  "integer",
                                  "boolean",
                                  "date",
                                  "datetime",
                                  "json"
                                ]
                              },
                              "required": {
                                "default": false,
                                "description": "Whether this extracted field is required for this step to succeed",
                                "type": "boolean"
                              },
                              "trim": {
                                "default": true,
                                "description": "Whether to trim extracted string values",
                                "type": "boolean"
                              },
                              "normalize": {
                                "default": "none",
                                "description": "Optional normalization applied to extracted string values",
                                "type": "string",
                                "enum": [
                                  "none",
                                  "lowercase",
                                  "uppercase"
                                ]
                              }
                            },
                            "required": [
                              "pattern"
                            ],
                            "description": "Regex extraction definition for one output field"
                          }
                        }
                      }
                    }
                  },
                  "required": [
                    "extract"
                  ],
                  "description": "Extract structured fields from message content using regex or an LLM engine"
                },
                {
                  "type": "object",
                  "properties": {
                    "filter": {
                      "type": "object",
                      "properties": {
                        "where": {
                          "type": "object",
                          "propertyNames": {
                            "type": "string"
                          },
                          "additionalProperties": {},
                          "description": "Filter conditions as field-value pairs. Records must match all conditions to pass through. Use an array for OR matching (e.g. folder_id: [inbox, archive]) and null to test for missing fields."
                        }
                      },
                      "required": [
                        "where"
                      ]
                    }
                  },
                  "required": [
                    "filter"
                  ],
                  "description": "Remove records that don't match the specified conditions"
                },
                {
                  "type": "object",
                  "properties": {
                    "map": {
                      "type": "object",
                      "properties": {
                        "fields": {
                          "type": "object",
                          "propertyNames": {
                            "type": "string"
                          },
                          "additionalProperties": {
                            "type": "string"
                          },
                          "description": "Field mapping rules. Key is the target field (e.g. data.vendor), value is the source field (e.g. data.from_email). The source value is copied into the target field for every record. No pattern matching or AI — purely mechanical copy/rename."
                        }
                      },
                      "required": [
                        "fields"
                      ]
                    }
                  },
                  "required": [
                    "map"
                  ],
                  "description": "Copy or rename record fields without pattern matching or AI"
                },
                {
                  "type": "object",
                  "properties": {
                    "validate": {
                      "type": "object",
                      "properties": {
                        "require": {
                          "default": [],
                          "description": "List of fields that must be present. Records missing any of these trigger the on_error action",
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "on_error": {
                          "default": "review",
                          "description": "Action when required fields are missing: drop discards the record, review flags it for human review, fail aborts the pipeline with an error",
                          "type": "string",
                          "enum": [
                            "drop",
                            "review",
                            "fail"
                          ]
                        }
                      }
                    }
                  },
                  "required": [
                    "validate"
                  ],
                  "description": "Check that required fields are present and take action on missing fields"
                },
                {
                  "type": "object",
                  "properties": {
                    "dedupe": {
                      "type": "object",
                      "properties": {
                        "by": {
                          "minItems": 1,
                          "type": "array",
                          "items": {
                            "type": "string"
                          },
                          "description": "Fields to group by for deduplication. Records with the same values in all specified fields are considered duplicates"
                        },
                        "strategy": {
                          "default": "latest",
                          "description": "Which record to keep from each group: first keeps the first encountered, latest keeps the most recent by received_at timestamp, merge combines all fields from all records in the group",
                          "type": "string",
                          "enum": [
                            "first",
                            "latest",
                            "merge"
                          ]
                        }
                      },
                      "required": [
                        "by"
                      ]
                    }
                  },
                  "required": [
                    "dedupe"
                  ],
                  "description": "Remove duplicate records based on field value equality"
                }
              ]
            },
            "description": "Ordered list of processing steps (classify, extract, filter, map, validate, dedupe)"
          },
          "store": {
            "type": "object",
            "properties": {
              "collection": {
